* {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Courier New', monospace;
    }

    body {
      background: radial-gradient(circle at center, #1f1f1f, #0b0b0b);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      overflow: hidden;
      color: white;
    }

    .game-container {
      display: flex;
      gap: 30px;
      align-items: center;
      background: rgba(20, 20, 20, 0.9);
      padding: 30px;
      border-radius: 20px;
      box-shadow: 0 0 30px rgba(0,255,255,0.3);
      border: 3px solid #00ffff;
    }

    .left-panel {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    canvas {
      border: 4px solid #00ffff;
      background: #111;
      box-shadow: 0 0 20px rgba(0,255,255,0.4);
    }

    .info-box {
      background: #151515;
      padding: 15px;
      border-radius: 12px;
      border: 2px solid #ff00ff;
      box-shadow: 0 0 10px rgba(255,0,255,0.3);
      text-align: center;
    }

    .info-box h2 {
      margin-bottom: 10px;
      color: #00ffff;
      font-size: 18px;
    }

    .score {
      font-size: 24px;
      color: #fff;
    }

    .controls {
      line-height: 1.8;
      font-size: 14px;
      color: #ddd;
    }

    .title {
      position: absolute;
      top: 30px;
      font-size: 42px;
      letter-spacing: 4px;
      color: #00ffff;
      text-shadow: 0 0 10px #00ffff;
    }

    .game-over {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: rgba(0,0,0,0.9);
      padding: 30px;
      border: 3px solid #ff0055;
      border-radius: 20px;
      text-align: center;
      display: none;
      z-index: 100;
    }

    .game-over h1 {
      color: #ff0055;
      margin-bottom: 15px;
    }

    .restart-btn {
      margin-top: 15px;
      padding: 10px 20px;
      border: none;
      background: #00ffff;
      color: black;
      font-size: 16px;
      border-radius: 8px;
      cursor: pointer;
      transition: 0.3s;
    }

    .restart-btn:hover {
      background: #ff00ff;
      color: white;
    }
